default_platform(:ios)

# Requisitos pendientes antes de que este lane pueda correr de verdad
# (ninguno existe todavia para Sazono, ver docs/13-app-mesero-capacitor.md):
#
# 1. Apple Developer Program (USD 99/año) — habilita team_id y certificados.
# 2. App Store Connect API Key (App Store Connect > Users and Access > Keys)
#    — se usa en vez de apple_id/password para que el login en CI no pida 2FA.
#    Genera un .p8; su contenido (base64) va en el secret ASC_KEY_CONTENT.
# 3. Registro de la app en App Store Connect con el bundle id
#    com.sazono.staff (Appfile).
# 4. Repo privado de git para fastlane match (guarda certificados/perfiles
#    de firma cifrados) — ver https://docs.fastlane.tools/actions/match/.
#    Sin esto, reemplazar match() por manual signing en Xcode.
#
# Secrets esperados en GitHub Actions (ver .github/workflows/ios-build.yml):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_CONTENT   (App Store Connect API key)
#   MATCH_GIT_URL, MATCH_PASSWORD                (fastlane match)

platform :ios do
  desc "Build y sube un build a TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true,
      git_url: ENV["MATCH_GIT_URL"]
    )

    increment_build_number(xcodeproj: "App/App.xcodeproj")

    build_app(
      project: "App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store"
    )

    upload_to_testflight(api_key: api_key)
  end
end
